---
import Layout from '../layouts/Layout.astro';

const HN_API = 'https://hacker-news.firebaseio.com/v0';

const storiesResponse = await fetch(`${HN_API}/topstories.json`);
const storyIds = await storiesResponse.json();
const topIds = storyIds.slice(0, 30);

const storyDetails = await Promise.all(
  topIds.map(async (id: number) => {
    const res = await fetch(`${HN_API}/item/${id}.json`);
    return res.json();
  })
);

const aiKeywords = ['ai', 'openai', 'gpt', 'llm', 'model', 'chatgpt', 'anthropic', 'claude', 'gemini', 'mistral', 'deepseek', 'google', 'meta', 'microsoft', 'machine learning', 'neural', 'transformer', 'nvidia', 'amazon', 'apple', 'xai', 'perplexity'];
const filteredStories = storyDetails.filter((story: any) => {
  if (!story || !story.title || story.type !== 'story') return false;
  const titleLower = story.title.toLowerCase();
  return aiKeywords.some(keyword => titleLower.includes(keyword));
});

const today = new Date().toLocaleDateString('en-US', { 
  weekday: 'long', 
  year: 'numeric', 
  month: 'long', 
  day: 'numeric' 
});

function getTopic(title: string): string {
  const t = title.toLowerCase();
  if (t.includes('openai') || t.includes('gpt') || t.includes('chatgpt')) return 'OpenAI';
  if (t.includes('google') || t.includes('gemini')) return 'Google';
  if (t.includes('meta') || t.includes('facebook')) return 'Meta';
  if (t.includes('anthropic') || t.includes('claude')) return 'Anthropic';
  if (t.includes('microsoft')) return 'Microsoft';
  if (t.includes('nvidia')) return 'NVIDIA';
  if (t.includes('security') || t.includes('hack') || t.includes('vulnerability')) return 'Security';
  if (t.includes('model') || t.includes('training')) return 'Research';
  if (t.includes('code') || t.includes('github') || t.includes('programming')) return 'Dev';
  return 'AI';
}

function getTopicColor(topic: string): string {
  const colors: Record<string, string> = {
    'OpenAI': 'bg-green-500/20 text-green-400',
    'Google': 'bg-blue-500/20 text-blue-400',
    'Meta': 'bg-indigo-500/20 text-indigo-400',
    'Anthropic': 'bg-purple-500/20 text-purple-400',
    'Microsoft': 'bg-cyan-500/20 text-cyan-400',
    'NVIDIA': 'bg-yellow-500/20 text-yellow-400',
    'Security': 'bg-red-500/20 text-red-400',
    'Research': 'bg-pink-500/20 text-pink-400',
    'Dev': 'bg-orange-500/20 text-orange-400',
    'AI': 'bg-gray-500/20 text-gray-400',
  };
  return colors[topic] || colors['AI'];
}
---

<Layout title="AI News">
  <div class="min-h-screen bg-[#0d0d0f] text-white">
    <!-- Header -->
    <header class="sticky top-0 z-50 backdrop-blur-xl bg-[#0d0d0f]/80 border-b border-white/5">
      <div class="max-w-7xl mx-auto px-4 md:px-8 py-4">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
          <div>
            <h1 class="text-2xl font-bold" style="font-family: 'Space Grotesk', sans-serif;">
              AI <span class="text-white/60">News</span>
            </h1>
            <p class="text-white/40 text-sm">{today}</p>
          </div>
          
          <!-- Controls -->
          <div class="flex items-center gap-3">
            <select id="sort-select" class="px-3 py-2 rounded-lg bg-white/5 border border-white/10 text-white text-sm focus:outline-none">
              <option value="score">Top</option>
              <option value="comments">Discussed</option>
              <option value="time">New</option>
            </select>
            
            <select id="filter-select" class="px-3 py-2 rounded-lg bg-white/5 border border-white/10 text-white text-sm focus:outline-none">
              <option value="all">All</option>
              <option value="openai">OpenAI</option>
              <option value="google">Google</option>
              <option value="meta">Meta</option>
              <option value="anthropic">Anthropic</option>
              <option value="nvidia">NVIDIA</option>
              <option value="security">Security</option>
            </select>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Grid -->
    <main class="max-w-7xl mx-auto px-4 md:px-8 py-8">
      <div id="news-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {filteredStories.map((story: any, index: number) => {
          const topic = getTopic(story.title);
          const topicColor = getTopicColor(topic);
          const isLarge = index < 3;
          
          return (
            <article 
              class="news-card group relative bg-white/[0.03] hover:bg-white/[0.06] border border-white/5 hover:border-white/15 rounded-2xl p-5 transition-all duration-300 cursor-pointer"
              data-score={story.score}
              data-comments={story.descendants || 0}
              data-time={story.time}
              data-topic={story.title.toLowerCase()}
              style={isLarge ? "md:col-span-1 lg:col-span-1" : ""}
            >
              <!-- Topic Tag -->
              <div class="flex items-center justify-between mb-3">
                <span class={`px-2 py-0.5 rounded-md text-xs font-medium ${topicColor}`}>
                  {topic}
                </span>
                <span class="text-white/30 text-xs">{story.score} pts</span>
              </div>
              
              <!-- Title -->
              <h2 class={`font-semibold leading-tight mb-3 text-white/90 group-hover:text-white transition-colors ${isLarge ? 'text-lg' : 'text-sm'}`}>
                {story.title}
              </h2>
              
              <!-- Meta -->
              <div class="flex items-center gap-4 text-xs text-white/40">
                <span class="flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                  </svg>
                  {story.descendants || 0}
                </span>
                <span>{story.by}</span>
                <span class="text-white/20">•</span>
                <span>{story.url ? new URL(story.url).hostname.replace('www.','').slice(0,15) : 'HN'}</span>
              </div>
              
              <!-- Hover Action -->
              <a 
                href={story.url || `https://news.ycombinator.com/item?id=${story.id}`}
                target="_blank"
                rel="noopener"
                class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200 rounded-2xl"
              >
                <span class="px-4 py-2 bg-white/10 backdrop-blur-sm rounded-full text-sm font-medium">
                  Read → 
                </span>
              </a>
            </article>
          );
        })}
      </div>
    </main>

    <!-- Footer -->
    <footer class="py-8 text-center">
      <p class="text-white/20 text-sm">
        Powered by <a href="https://news.ycombinator.com" class="hover:text-white/40">Hacker News</a>
      </p>
    </footer>
  </div>
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap');
</style>

<script>
  const grid = document.getElementById('news-grid');
  const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
  const filterSelect = document.getElementById('filter-select') as HTMLSelectElement;
  
  function filterAndSort() {
    const cards = Array.from(document.querySelectorAll('.news-card'));
    const sortBy = sortSelect.value;
    const filterBy = filterSelect.value;
    
    cards.forEach(card => {
      const el = card as HTMLElement;
      const topic = el.dataset.topic || '';
      el.style.display = (filterBy === 'all' || topic.includes(filterBy)) ? 'block' : 'none';
    });
    
    const visible = cards.filter(c => (c as HTMLElement).style.display !== 'none') as HTMLElement[];
    
    visible.sort((a, b) => {
      const getVal = (el: HTMLElement, key: string) => parseInt(el.dataset[key] || '0');
      const key = sortBy === 'comments' ? 'comments' : sortBy === 'time' ? 'time' : 'score';
      return getVal(b, key) - getVal(a, key);
    });
    
    visible.forEach(card => grid?.appendChild(card));
  }
  
  sortSelect?.addEventListener('change', filterAndSort);
  filterSelect?.addEventListener('change', filterAndSort);
</script>
