---
import Layout from '../layouts/Layout.astro';

const HN_API = 'https://hacker-news.firebaseio.com/v0';

const storiesResponse = await fetch(`${HN_API}/topstories.json`);
const storyIds = await storiesResponse.json();
const topIds = storyIds.slice(0, 30);

const storyDetails = await Promise.all(
  topIds.map(async (id: number) => {
    const res = await fetch(`${HN_API}/item/${id}.json`);
    return res.json();
  })
);

const aiKeywords = ['ai', 'openai', 'gpt', 'llm', 'model', 'chatgpt', 'anthropic', 'claude', 'gemini', 'mistral', 'deepseek', 'google', 'meta', 'microsoft', 'machine learning', 'neural', 'transformer', 'nvidia', 'amazon', 'apple', 'xai', 'perplexity'];
const filteredStories = storyDetails.filter((story: any) => {
  if (!story || !story.title || story.type !== 'story') return false;
  const titleLower = story.title.toLowerCase();
  return aiKeywords.some(keyword => titleLower.includes(keyword));
}).slice(0, 15);

// Split into featured (top 3) and rest
const featured = filteredStories.slice(0, 3);
const rest = filteredStories.slice(3);

const today = new Date().toLocaleDateString('en-US', { 
  weekday: 'long', 
  year: 'numeric', 
  month: 'long', 
  day: 'numeric' 
});

function getDomain(url: string) {
  try {
    return new URL(url).hostname.replace('www.', '');
  } catch {
    return 'news.ycombinator.com';
  }
}
---

<Layout title="AI News | Daily">
  <div class="min-h-screen bg-[#0a0a0b] text-white">
    <!-- Gradient Background -->
    <div class="fixed inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-indigo-900/20 via-[#0a0a0b] to-[#0a0a0b] pointer-events-none"></div>
    
    <main class="relative max-w-4xl mx-auto px-6 py-12">
      <!-- Header -->
      <header class="mb-16 text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 text-sm text-white/60 mb-6">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          Updated daily
        </div>
        <h1 class="text-5xl md:text-6xl font-bold tracking-tight mb-4 bg-gradient-to-r from-white via-white to-white/60 bg-clip-text text-transparent">
          AI News
        </h1>
        <p class="text-white/40 text-lg">{today}</p>
      </header>

      <!-- Featured Stories -->
      {featured.length > 0 && (
        <section class="mb-12">
          <h2 class="text-xs font-semibold uppercase tracking-widest text-white/30 mb-6">Featured</h2>
          <div class="grid gap-4">
            {featured.map((story: any, index: number) => (
              <a 
                href={story.url || `https://news.ycombinator.com/item?id=${story.id}`}
                target="_blank"
                rel="noopener"
                class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-white/5 to-white/[0.02] border border-white/5 hover:border-white/20 transition-all duration-500 hover:shadow-2xl hover:shadow-indigo-500/10"
              >
                <div class="absolute inset-0 bg-gradient-to-r from-indigo-500/5 to-purple-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="relative p-6 md:p-8">
                  <div class="flex items-start gap-4">
                    <span class="text-4xl md:text-5xl font-bold text-white/10 group-hover:text-white/20 transition-colors">{index + 1}</span>
                    <div class="flex-1 min-w-0">
                      <h3 class="text-xl md:text-2xl font-semibold text-white/90 group-hover:text-white transition-colors line-clamp-2 mb-3">
                        {story.title}
                      </h3>
                      <div class="flex items-center gap-4 text-sm text-white/40">
                        <span class="flex items-center gap-1">
                          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                          {story.score}
                        </span>
                        <span class="text-white/20">•</span>
                        <span>{story.by}</span>
                        <span class="text-white/20">•</span>
                        <span class="text-indigo-400">{story.url ? getDomain(story.url) : 'HN'}</span>
                      </div>
                    </div>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Rest of Stories -->
      {rest.length > 0 && (
        <section>
          <h2 class="text-xs font-semibold uppercase tracking-widest text-white/30 mb-6">Latest</h2>
          <div class="grid gap-3">
            {rest.map((story: any) => (
              <a 
                href={story.url || `https://news.ycombinator.com/item?id=${story.id}`}
                target="_blank"
                rel="noopener"
                class="group flex items-center gap-4 p-4 rounded-xl bg-white/[0.02] border border-white/5 hover:bg-white/5 hover:border-white/10 transition-all duration-300"
              >
                <span class="text-lg font-semibold text-white/20 group-hover:text-white/40 transition-colors w-8">
                  {story.score}
                </span>
                <div class="flex-1 min-w-0">
                  <h3 class="text-base text-white/80 group-hover:text-white transition-colors line-clamp-1">
                    {story.title}
                  </h3>
                  <p class="text-sm text-white/40 mt-1">
                    {story.by} • {story.url ? getDomain(story.url) : 'HN'}
                  </p>
                </div>
                <svg class="w-5 h-5 text-white/20 group-hover:text-white/60 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Footer -->
      <footer class="mt-20 pt-8 border-t border-white/5 text-center">
        <p class="text-white/30 text-sm">
          Powered by <a href="https://news.ycombinator.com" target="_blank" class="text-indigo-400 hover:text-indigo-300 transition-colors">Hacker News</a> • Built with <span class="text-white/50">Astro</span>
        </p>
      </footer>
    </main>
  </div>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
