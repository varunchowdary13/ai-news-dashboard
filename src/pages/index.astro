---
import Layout from '../layouts/Layout.astro';

const HN_API = 'https://hacker-news.firebaseio.com/v0';

const storiesResponse = await fetch(`${HN_API}/topstories.json`);
const storyIds = await storiesResponse.json();
const topIds = storyIds.slice(0, 30);

const storyDetails = await Promise.all(
  topIds.map(async (id: number) => {
    const res = await fetch(`${HN_API}/item/${id}.json`);
    return res.json();
  })
);

const aiKeywords = ['ai', 'openai', 'gpt', 'llm', 'model', 'chatgpt', 'anthropic', 'claude', 'gemini', 'mistral', 'deepseek', 'google', 'meta', 'microsoft', 'machine learning', 'neural', 'transformer', 'nvidia', 'amazon', 'apple', 'xai', 'perplexity'];
const filteredStories = storyDetails.filter((story: any) => {
  if (!story || !story.title || story.type !== 'story') return false;
  const titleLower = story.title.toLowerCase();
  return aiKeywords.some(keyword => titleLower.includes(keyword));
}).slice(0, 12);

const today = new Date().toLocaleDateString('en-US', { 
  weekday: 'long', 
  year: 'numeric', 
  month: 'long', 
  day: 'numeric' 
});

function getDomain(url: string) {
  try {
    return new URL(url).hostname.replace('www.', '');
  } catch {
    return 'news.ycombinator.com';
  }
}

function getGradientForTitle(title: string): string {
  const hash = title.split('').reduce((a, b) => ((a << 5) - a + b.charCodeAt(0)) | 0, 0);
  const gradients = [
    'from-pink-500 via-red-500 to-yellow-500',
    'from-green-400 via-cyan-500 to-blue-500',
    'from-purple-500 via-pink-500 to-red-500',
    'from-yellow-400 via-orange-500 to-red-500',
    'from-cyan-400 via-blue-500 to-purple-500',
    'from-indigo-500 via-purple-500 to-pink-500',
    'from-emerald-400 via-teal-500 to-cyan-500',
    'from-orange-400 via-pink-500 to-purple-500',
  ];
  return gradients[Math.abs(hash) % gradients.length];
}

function getEmojiForTitle(title: string): string {
  const titleLower = title.toLowerCase();
  if (titleLower.includes('openai') || titleLower.includes('gpt') || titleLower.includes('chatgpt')) return '🤖';
  if (titleLower.includes('google') || titleLower.includes('gemini')) return '🔷';
  if (titleLower.includes('meta') || titleLower.includes('facebook')) return '📘';
  if (titleLower.includes('anthropic') || titleLower.includes('claude')) return '🧠';
  if (titleLower.includes('microsoft')) return '🪟';
  if (titleLower.includes('nvidia') || titleLower.includes('chip')) return '⚡';
  if (titleLower.includes('model') || titleLower.includes('training')) return '🧪';
  if (titleLower.includes('security') || titleLower.includes('hack')) return '🔒';
  if (titleLower.includes('code') || titleLower.includes('programming')) return '💻';
  if (titleLower.includes('research') || titleLower.includes('paper')) return '📄';
  return '🚀';
}

function generateSummary(title: string, score: number): string[] {
  const summaries: string[] = [];
  
  if (title.toLowerCase().includes('openai')) {
    summaries.push("OpenAI announces new developments in AI capabilities and safety measures.");
  } else if (title.toLowerCase().includes('google')) {
    summaries.push("Google pushes boundaries with new AI integrations across products.");
  } else if (title.toLowerCase().includes('meta')) {
    summaries.push("Meta unveils advances in open-source AI and infrastructure.");
  } else if (title.toLowerCase().includes('anthropic')) {
    summaries.push("Anthropic reveals improvements in Claude's reasoning abilities.");
  } else if (title.toLowerCase().includes('nvidia')) {
    summaries.push("NVIDIA announces next-generation AI hardware offerings.");
  } else if (title.toLowerCase().includes('model')) {
    summaries.push("New AI model release shows significant performance improvements.");
  } else if (title.toLowerCase().includes('security') || title.toLowerCase().includes('hack')) {
    summaries.push("Security researchers discover and disclose critical AI vulnerabilities.");
  } else {
    summaries.push(`This story has received ${score} points from the community.`);
    summaries.push("Click to read the full discussion on Hacker News.");
  }
  
  // Add a second "page" of content
  summaries.push("The implications of this development could shape the future of AI.");
  
  return summaries;
}
---

<Layout title="AI News | Visual Edition">
  <!-- Interactive mouse-following gradient -->
  <div id="mouse-gradient" class="fixed inset-0 pointer-events-none opacity-30 transition-opacity duration-700"></div>
  
  <!-- Floating particles canvas -->
  <canvas id="particles" class="fixed inset-0 pointer-events-none"></canvas>

  <div class="min-h-screen bg-[#0a0a0b] text-white relative overflow-x-hidden">
    <!-- Dynamic gradient background -->
    <div id="bg-gradient" class="fixed inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-indigo-900/20 via-[#0a0a0b] to-[#0a0a0b] pointer-events-none transition-transform duration-100 ease-out"></div>
    
    <!-- Mouse glow orb -->
    <div id="mouse-orb" class="fixed w-96 h-96 rounded-full pointer-events-none opacity-20 blur-3xl transition-transform duration-300 ease-out bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500"></div>
    
    <main class="relative max-w-6xl mx-auto px-6 py-12">
      <!-- Header -->
      <header class="mb-16 text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 text-sm text-white/60 mb-6 hover:bg-white/10 transition-colors cursor-default">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          Updated daily
        </div>
        <h1 class="text-5xl md:text-6xl font-bold tracking-tight mb-4 bg-gradient-to-r from-white via-white to-white/60 bg-clip-text text-transparent">
          AI News
        </h1>
        <p class="text-white/40 text-lg">{today}</p>
        <p class="text-white/30 text-sm mt-2">Swipe or click cards to flip through pages</p>
      </header>

      <!-- Visual Story Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {filteredStories.map((story: any, index: number) => {
          const gradient = getGradientForTitle(story.title);
          const emoji = getEmojiForTitle(story.title);
          const summary = generateSummary(story.title, story.score);
          
          return (
            <div class="story-card-container" style={`--delay: ${index * 0.1}s`}>
              <!-- Book-style card with flip -->
              <div class="book-card group" data-story={JSON.stringify({ title: story.title, url: story.url, id: story.id })}>
                <!-- Front Cover -->
                <div class="book-cover relative overflow-hidden rounded-2xl">
                  <!-- Abstract art background -->
                  <div class={`absolute inset-0 bg-gradient-to-br ${gradient} opacity-80`}></div>
                  <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width=%2260%22 height=%2260%22 viewBox=%220 0 60 60%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cg fill=%22none%22 fill-rule=%22evenodd%22%3E%3Cg fill=%22%23ffffff%22 fill-opacity=%220.05%22%3E%3Cpath d=%22M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z%22/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')]`}></div>
                  
                  <!-- Floating emoji icon -->
                  <div class="absolute top-4 right-4 text-6xl opacity-30 transform group-hover:scale-110 transition-transform duration-500">
                    {emoji}
                  </div>
                  
                  <!-- Cover content -->
                  <div class="relative h-80 p-6 flex flex-col justify-end">
                    <div class="absolute top-4 left-4 px-3 py-1 rounded-full bg-white/20 backdrop-blur-sm text-xs font-medium">
                      Page 1 of 2
                    </div>
                    
                    <h3 class="text-2xl font-bold text-white mb-2 line-clamp-2 drop-shadow-lg">
                      {story.title}
                    </h3>
                    
                    <div class="flex items-center gap-3 text-white/80 text-sm">
                      <span class="flex items-center gap-1">
                        <span class="text-lg">⭐</span>
                        {story.score}
                      </span>
                      <span>•</span>
                      <span>{story.by}</span>
                    </div>
                    
                    <div class="mt-4 flex items-center justify-between">
                      <span class="text-white/60 text-sm flex items-center gap-1">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122"/>
                        </svg>
                        Click to flip
                      </span>
                      <span class="text-2xl">📖</span>
                    </div>
                  </div>
                </div>
                
                <!-- Back Page (Page 2) -->
                <div class="book-page book-page-back relative overflow-hidden rounded-2xl">
                  <div class="absolute inset-0 bg-gradient-to-br from-zinc-900 to-zinc-800"></div>
                  <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width=%2220%22 height=%2220%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cpath d=%22M0 0h20v20H0V0zm1 1h18v18H1V1z%22 fill=%22%23ffffff%22 fill-opacity=%220.02%22/%3E%3C/svg%3E')]"></div>
                  
                  <div class="relative h-80 p-6 flex flex-col">
                    <div class="flex items-center justify-between mb-4">
                      <span class="px-3 py-1 rounded-full bg-indigo-500/20 text-indigo-300 text-xs font-medium">
                        Page 2 of 2
                      </span>
                      <button class="flip-back-btn p-2 rounded-full bg-white/10 hover:bg-white/20 transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                        </svg>
                      </button>
                    </div>
                    
                    <div class="flex-1 flex items-center justify-center">
                      <p class="text-white/70 text-center leading-relaxed">
                        {summary[0]}
                      </p>
                    </div>
                    
                    <div class="mt-4 pt-4 border-t border-white/10">
                      <p class="text-white/50 text-sm text-center mb-4">
                        {summary[1]}
                      </p>
                      
                      <a 
                        href={story.url || `https://news.ycombinator.com/item?id=${story.id}`}
                        target="_blank"
                        rel="noopener"
                        class="need-details-btn block w-full py-3 px-4 rounded-xl bg-gradient-to-r from-indigo-500 to-purple-500 hover:from-indigo-600 hover:to-purple-600 text-white font-medium text-center transition-all duration-300 hover:shadow-lg hover:shadow-indigo-500/25"
                      >
                        Need more details? →
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>

      <!-- Footer -->
      <footer class="mt-20 pt-8 border-t border-white/5 text-center">
        <p class="text-white/30 text-sm">
          Powered by <a href="https://news.ycombinator.com" target="_blank" class="text-indigo-400 hover:text-indigo-300 transition-colors">Hacker News</a> • Built with <span class="text-white/50">Astro</span>
        </p>
      </footer>
    </main>
  </div>
</Layout>

<script>
  // Mouse orb following
  const orb = document.getElementById('mouse-orb');
  const bgGradient = document.getElementById('bg-gradient');
  
  let mouseX = 0;
  let mouseY = 0;
  let orbX = 0;
  let orbY = 0;
  
  document.addEventListener('mousemove', (e) => {
    mouseX = e.clientX;
    mouseY = e.clientY;
  });
  
  function animateOrb() {
    orbX += (mouseX - orbX) * 0.08;
    orbY += (mouseY - orbY) * 0.08;
    
    if (orb) {
      orb.style.transform = `translate(${orbX - 384}px, ${orbY - 384}px)`;
    }
    
    if (bgGradient) {
      const moveX = (mouseX - window.innerWidth / 2) * 0.02;
      const moveY = (mouseY - window.innerHeight / 2) * 0.02;
      bgGradient.style.transform = `translate(${moveX}px, ${moveY}px)`;
    }
    
    requestAnimationFrame(animateOrb);
  }
  
  animateOrb();
  
  // Floating particles
  const canvas = document.getElementById('particles') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d');
  
  function resizeCanvas() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  resizeCanvas();
  window.addEventListener('resize', resizeCanvas);
  
  interface Particle {
    x: number;
    y: number;
    vx: number;
    vy: number;
    size: number;
    alpha: number;
  }
  
  const particles: Particle[] = [];
  const particleCount = 40;
  
  for (let i = 0; i < particleCount; i++) {
    particles.push({
      x: Math.random() * canvas.width,
      y: Math.random() * canvas.height,
      vx: (Math.random() - 0.5) * 0.3,
      vy: (Math.random() - 0.5) * 0.3,
      size: Math.random() * 2 + 1,
      alpha: Math.random() * 0.3 + 0.1
    });
  }
  
  function animateParticles() {
    if (!ctx) return;
    
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    particles.forEach((p, i) => {
      p.x += p.vx;
      p.y += p.vy;
      
      if (p.x < 0) p.x = canvas.width;
      if (p.x > canvas.width) p.x = 0;
      if (p.y < 0) p.y = canvas.height;
      if (p.y > canvas.height) p.y = 0;
      
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(255, 255, 255, ${p.alpha})`;
      ctx.fill();
      
      particles.slice(i + 1).forEach(p2 => {
        const dx = p.x - p2.x;
        const dy = p.y - p2.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        
        if (dist < 120) {
          ctx.beginPath();
          ctx.moveTo(p.x, p.y);
          ctx.lineTo(p2.x, p2.y);
          ctx.strokeStyle = `rgba(255, 255, 255, ${0.05 * (1 - dist / 120)})`;
          ctx.stroke();
        }
      });
    });
    
    requestAnimationFrame(animateParticles);
  }
  
  animateParticles();
  
  // Card flip functionality
  document.querySelectorAll('.book-card').forEach(card => {
    const cover = card.querySelector('.book-cover') as HTMLElement;
    const back = card.querySelector('.book-page-back') as HTMLElement;
    const flipBackBtn = card.querySelector('.flip-back-btn') as HTMLElement;
    
    // Click to flip
    card.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('.need-details-btn') || 
          (e.target as HTMLElement).closest('.flip-back-btn')) {
        return;
      }
      card.classList.toggle('flipped');
    });
    
    // Flip back button
    if (flipBackBtn) {
      flipBackBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        card.classList.remove('flipped');
      });
    }
  });
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .story-card-container {
    perspective: 1000px;
    animation: fadeInUp 0.6s ease-out backwards;
    animation-delay: var(--delay);
  }
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .book-card {
    position: relative;
    width: 100%;
    height: 320px;
    transform-style: preserve-3d;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
  }
  
  .book-card.flipped {
    transform: rotateY(-180deg);
  }
  
  .book-cover,
  .book-page-back {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }
  
  .book-page-back {
    transform: rotateY(180deg);
    -webkit-transform: rotateY(180deg);
  }
  
  .need-details-btn {
    transform: translateY(0);
    transition: all 0.3s ease;
  }
  
  .need-details-btn:hover {
    transform: translateY(-2px);
  }
  
  .flip-back-btn {
    cursor: pointer;
  }
</style>
