---
import Layout from '../layouts/Layout.astro';

const HN_API = 'https://hacker-news.firebaseio.com/v0';

const storiesResponse = await fetch(`${HN_API}/topstories.json`);
const storyIds = await storiesResponse.json();
const topIds = storyIds.slice(0, 30);

const storyDetails = await Promise.all(
  topIds.map(async (id: number) => {
    const res = await fetch(`${HN_API}/item/${id}.json`);
    return res.json();
  })
);

const aiKeywords = ['ai', 'openai', 'gpt', 'llm', 'model', 'chatgpt', 'anthropic', 'claude', 'gemini', 'mistral', 'deepseek', 'google', 'meta', 'microsoft', 'machine learning', 'neural', 'transformer', 'nvidia', 'amazon', 'apple', 'xai', 'perplexity'];
const filteredStories = storyDetails.filter((story: any) => {
  if (!story || !story.title || story.type !== 'story') return false;
  const titleLower = story.title.toLowerCase();
  return aiKeywords.some(keyword => titleLower.includes(keyword));
}).slice(0, 6);

const today = new Date().toLocaleDateString('en-US', { 
  weekday: 'long', 
  year: 'numeric', 
  month: 'long', 
  day: 'numeric' 
});

function getEmojiForTitle(title: string): string {
  const titleLower = title.toLowerCase();
  if (titleLower.includes('openai') || titleLower.includes('gpt')) return '🤖';
  if (titleLower.includes('google')) return '🔷';
  if (titleLower.includes('meta')) return '📘';
  if (titleLower.includes('anthropic')) return '🧠';
  if (titleLower.includes('microsoft')) return '🪟';
  if (titleLower.includes('nvidia')) return '⚡';
  if (titleLower.includes('model')) return '🧪';
  if (titleLower.includes('security')) return '🔒';
  return '🚀';
}

function getGradient(index: number): string {
  const gradients = [
    'from-slate-900 via-purple-900 to-slate-900',
    'from-zinc-900 via-amber-900 to-zinc-900', 
    'from-zinc-900 via-rose-900 to-zinc-900',
    'from-zinc-900 via-emerald-900 to-zinc-900',
    'from-zinc-900 via-cyan-900 to-zinc-900',
    'from-zinc-900 via-violet-900 to-zinc-900',
  ];
  return gradients[index % gradients.length];
}

function generateBulletPoints(title: string, story: any): string[] {
  const points = [
    `${story.score} points from the HN community`,
    `Posted by ${story.by}`,
    story.url ? `Source: ${new URL(story.url).hostname}` : 'Discussion on Hacker News',
  ];
  
  const titleLower = title.toLowerCase();
  
  if (titleLower.includes('openai') || titleLower.includes('gpt')) {
    points.unshift("OpenAI announces new AI capabilities");
  } else if (titleLower.includes('google')) {
    points.unshift("Google unveils new AI integrations");
  } else if (titleLower.includes('meta')) {
    points.unshift("Meta advances open-source AI efforts");
  } else if (titleLower.includes('anthropic')) {
    points.unshift("Anthropic releases Claude improvements");
  } else if (titleLower.includes('nvidia')) {
    points.unshift("NVIDIA announces new AI hardware");
  } else if (titleLower.includes('model')) {
    points.unshift("New AI model shows breakthrough performance");
  } else if (titleLower.includes('security') || titleLower.includes('hack')) {
    points.unshift("Critical AI security vulnerability discovered");
  } else {
    points.unshift(title.slice(0, 60) + (title.length > 60 ? '...' : ''));
  }
  
  return points;
}
---

<Layout title="AI News | The Daily Brief">
  <canvas id="particles" class="fixed inset-0 pointer-events-none"></canvas>

  <div class="min-h-screen bg-[#0a0a0b] text-white relative overflow-hidden">
    <!-- Gradient orbs -->
    <div id="orb-1" class="fixed w-[500px] h-[500px] rounded-full pointer-events-none opacity-10 blur-3xl bg-gradient-to-r from-indigo-500 to-purple-500"></div>
    <div id="orb-2" class="fixed w-[400px] h-[400px] rounded-full pointer-events-none opacity-10 blur-3xl bg-gradient-to-r from-pink-500 to-rose-500"></div>
    
    <main class="relative z-10 min-h-screen flex flex-col items-center justify-center p-4 md:p-8">
      <!-- Header -->
      <header class="text-center mb-8">
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-2">AI News</h1>
        <p class="text-white/40">{today}</p>
        <p class="text-white/30 text-sm mt-2">← Click edges to flip pages →</p>
      </header>

      <!-- Book Container -->
      <div class="book-container perspective-2000">
        <div id="book" class="book relative w-[340px] md:w-[800px] h-[480px] transform-style-3d transition-transform duration-500">
          
          {/* Cover */}
          <div class="book-cover absolute inset-0 rounded-lg shadow-2xl cursor-pointer" style="transform: translateZ(10px)">
            <div class="absolute inset-0 bg-gradient-to-br from-slate-800 to-slate-900 rounded-lg border border-white/10"></div>
            <div class="absolute inset-0 flex flex-col items-center justify-center p-8 text-center">
              <div class="text-8xl mb-6">📰</div>
              <h2 class="text-3xl font-bold mb-2">AI Daily</h2>
              <p class="text-white/40 mb-8">Your AI news briefing</p>
              <p class="text-white/30 text-sm animate-pulse">Click to open →</p>
            </div>
            <!-- Spine -->
            <div class="absolute left-0 top-0 bottom-0 w-8 bg-gradient-to-r from-black/30 to-transparent rounded-l-lg"></div>
          </div>

          {/* Pages - we'll dynamically generate these */}
          {filteredStories.map((story: any, storyIndex: number) => {
            const bullets = generateBulletPoints(story.title, story);
            const gradient = getGradient(storyIndex);
            const emoji = getEmojiForTitle(story.title);
            
            // Create 2 pages per story (front and back)
            return (
              <>
                {/* Left Page */}
                <div class={`book-page absolute inset-0 rounded-lg shadow-xl overflow-hidden ${storyIndex === 0 ? 'active' : ''}`} 
                     data-page={storyIndex * 2} 
                     style="transform: rotateY(0deg) translateZ(0px);">
                  <div class={`absolute inset-0 bg-gradient-to-br ${gradient} p-6 md:p-10`}>
                    <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width=%2260%22 height=%2260%22 viewBox=%220 0 60 60%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cg fill=%22none%22 fill-rule=%22evenodd%22%3E%3Cg fill=%22%23ffffff%22 fill-opacity=%220.03%22%3E%3Cpath d=%22M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z%22/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')]`}></div>
                    
                    <!-- Page number -->
                    <div class="absolute bottom-4 left-6 text-white/20 font-serif text-sm">Page {storyIndex * 2 + 1}</div>
                    
                    <!-- Content -->
                    <div class="relative h-full flex flex-col">
                      <div class="flex items-center gap-3 mb-4">
                        <span class="text-4xl">{emoji}</span>
                        <span class="text-white/60 text-sm">Story {storyIndex + 1} of {filteredStories.length}</span>
                      </div>
                      
                      <h3 class="text-xl md:text-2xl font-bold mb-6 leading-tight">
                        {story.title.slice(0, 80)}{story.title.length > 80 ? '...' : ''}
                      </h3>
                      
                      <ul class="space-y-3 flex-1">
                        {bullets.map((point, i) => (
                          <li class="flex items-start gap-3 text-white/70">
                            <span class="text-indigo-400 mt-1">•</span>
                            <span class="text-sm md:text-base">{point}</span>
                          </li>
                        ))}
                      </ul>
                      
                      <div class="mt-4 pt-4 border-t border-white/10">
                        <p class="text-white/40 text-sm">Click right edge → to continue</p>
                      </div>
                    </div>
                  </div>
                  <!-- Page edge/shadow -->
                  <div class="absolute right-0 top-0 bottom-0 w-px bg-gradient-to-b from-white/20 via-white/5 to-transparent"></div>
                </div>
                
                {/* Right Page */}
                <div class="book-page absolute inset-0 rounded-lg shadow-xl overflow-hidden" 
                     data-page={storyIndex * 2 + 1}
                     style="transform: rotateY(180deg) translateZ(0px);">
                  <div class={`absolute inset-0 bg-gradient-to-bl ${gradient} p-6 md:p-10`}>
                    <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width=%2260%22 height=%2260%22 viewBox=%220 0 60 60%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cg fill=%22none%22 fill-rule=%22evenodd%22%3E%3Cg fill=%22%23ffffff%22 fill-opacity=%220.03%22%3E%3Cpath d=%22M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z%22/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')]`}></div>
                    
                    <!-- Page number -->
                    <div class="absolute bottom-4 right-6 text-white/20 font-serif text-sm">Page {storyIndex * 2 + 2}</div>
                    
                    <!-- Content -->
                    <div class="relative h-full flex flex-col">
                      <div class="flex items-center gap-3 mb-6">
                        <span class="text-4xl">📖</span>
                        <span class="text-white/60 text-sm">Read full story</span>
                      </div>
                      
                      <div class="flex-1 flex flex-col items-center justify-center">
                        <p class="text-white/70 text-center mb-6 leading-relaxed">
                          Click the button below to read the complete article and join the discussion on Hacker News.
                        </p>
                        
                        <a 
                          href={story.url || `https://news.ycombinator.com/item?id=${story.id}`}
                          target="_blank"
                          rel="noopener"
                          class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 hover:bg-white/20 border border-white/20 rounded-full transition-all duration-300 hover:scale-105"
                        >
                          <span>Read More</span>
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                          </svg>
                        </a>
                      </div>
                      
                      <div class="mt-4 pt-4 border-t border-white/10">
                        <p class="text-white/40 text-sm">← Click left edge to go back</p>
                      </div>
                    </div>
                  </div>
                  <!-- Page edge/shadow -->
                  <div class="absolute left-0 top-0 bottom-0 w-px bg-gradient-to-b from-white/20 via-white/5 to-transparent"></div>
                </div>
              </>
            );
          })}
          
          {/* Back cover */}
          <div class="book-cover absolute inset-0 rounded-lg" style="transform: translateZ(10px) rotateY(180deg)">
            <div class="absolute inset-0 bg-gradient-to-br from-slate-900 to-slate-800 rounded-lg border border-white/5"></div>
            <div class="absolute inset-0 flex flex-col items-center justify-center p-8 text-center">
              <p class="text-white/30 mb-4">End of today's briefing</p>
              <p class="text-white/20 text-sm">Come back tomorrow for more</p>
              <button id="restart-btn" class="mt-8 px-6 py-2 bg-white/10 hover:bg-white/20 rounded-full text-sm transition-colors">
                Start Over
              </button>
            </div>
            <div class="absolute right-0 top-0 bottom-0 w-8 bg-gradient-to-l from-black/30 to-transparent rounded-r-lg"></div>
          </div>
        </div>
      </div>

      <!-- Footer -->
      <footer class="mt-8 text-center">
        <p class="text-white/20 text-xs">
          Powered by Hacker News • Built with Astro
        </p>
      </footer>
    </main>
  </div>
</Layout>

<style>
  .perspective-2000 {
    perspective: 2000px;
  }
  
  .transform-style-3d {
    transform-style: preserve-3d;
  }
  
  .book {
    transform-style: preserve-3d;
  }
  
  .book-cover,
  .book-page {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }
</style>

<script>
  // Floating orbs
  const orb1 = document.getElementById('orb-1');
  const orb2 = document.getElementById('orb-2');
  
  let mouseX = 0;
  let mouseY = 0;
  let orb1X = 0, orb1Y = 0;
  let orb2X = 0, orb2Y = 0;
  
  document.addEventListener('mousemove', (e) => {
    mouseX = e.clientX;
    mouseY = e.clientY;
  });
  
  function animateOrbs() {
    orb1X += (mouseX - orb1X) * 0.02;
    orb1Y += (mouseY - orb1Y) * 0.02;
    orb2X += (mouseX - 200 - orb2X) * 0.015;
    orb2Y += (mouseY - 200 - orb2Y) * 0.015;
    
    if (orb1) orb1.style.transform = `translate(${orb1X - 250}px, ${orb1Y - 250}px)`;
    if (orb2) orb2.style.transform = `translate(${orb2X - 200}px, ${orb2Y - 200}px)`;
    
    requestAnimationFrame(animateOrbs);
  }
  animateOrbs();
  
  // Floating particles
  const canvas = document.getElementById('particles') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d');
  
  function resizeCanvas() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  resizeCanvas();
  window.addEventListener('resize', resizeCanvas);
  
  interface Particle {
    x: number;
    y: number;
    vx: number;
    vy: number;
    size: number;
    alpha: number;
  }
  
  const particles: Particle[] = [];
  for (let i = 0; i < 30; i++) {
    particles.push({
      x: Math.random() * canvas.width,
      y: Math.random() * canvas.height,
      vx: (Math.random() - 0.5) * 0.2,
      vy: (Math.random() - 0.5) * 0.2,
      size: Math.random() * 1.5 + 0.5,
      alpha: Math.random() * 0.2 + 0.05
    });
  }
  
  function animateParticles() {
    if (!ctx) return;
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    particles.forEach(p => {
      p.x += p.vx;
      p.y += p.vy;
      if (p.x < 0) p.x = canvas.width;
      if (p.x > canvas.width) p.x = 0;
      if (p.y < 0) p.y = canvas.height;
      if (p.y > canvas.height) p.y = 0;
      
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(255, 255, 255, ${p.alpha})`;
      ctx.fill();
    });
    
    requestAnimationFrame(animateParticles);
  }
  animateParticles();
  
  // Book flipping logic
  const book = document.getElementById('book') as HTMLElement;
  const cover = book.querySelector('.book-cover') as HTMLElement;
  const pages = document.querySelectorAll('.book-page');
  const restartBtn = document.getElementById('restart-btn');
  
  let currentPage = 0;
  let isFlipping = false;
  const totalPages = pages.length + 1; // +1 for cover
  
  // Open book on first click
  cover.addEventListener('click', () => {
    if (isFlipping) return;
    isFlipping = true;
    cover.style.transition = 'transform 0.8s ease-in-out';
    cover.style.transform = 'translateZ(10px) rotateY(-180deg)';
    setTimeout(() => {
      isFlipping = false;
      currentPage = 0;
    }, 800);
  });
  
  // Page click handlers
  pages.forEach((page, index) => {
    const pageEl = page as HTMLElement;
    
    // Click right side of book - flip forward
    pageEl.addEventListener('click', (e) => {
      if (isFlipping) return;
      
      const rect = pageEl.getBoundingClientRect();
      const x = (e as MouseEvent).clientX - rect.left;
      const isRightHalf = x > rect.width / 2;
      
      if (isRightHalf && currentPage < pages.length - 1) {
        flipForward();
      } else if (!isRightHalf && currentPage > 0) {
        flipBackward();
      }
    });
  });
  
  function flipForward() {
    if (isFlipping || currentPage >= pages.length - 1) return;
    isFlipping = true;
    
    const currentPageEl = pages[currentPage] as HTMLElement;
    const nextPageEl = pages[currentPage + 1] as HTMLElement;
    
    // Animate current page flipping away
    currentPageEl.style.transition = 'transform 0.6s ease-in';
    currentPageEl.style.transform = 'rotateY(-180deg) translateZ(-5px)';
    currentPageEl.style.zIndex = '5';
    
    setTimeout(() => {
      currentPageEl.style.zIndex = '0';
      currentPageEl.style.transition = '';
      currentPageEl.style.transform = 'rotateY(0deg) translateZ(0px)';
      
      // Bring next page to front
      nextPageEl.style.zIndex = '10';
      nextPageEl.style.transition = 'transform 0.6s ease-out';
      nextPageEl.style.transform = 'rotateY(0deg) translateZ(0px)';
      
      currentPage++;
      
      setTimeout(() => {
        isFlipping = false;
      }, 400);
    }, 600);
  }
  
  function flipBackward() {
    if (isFlipping || currentPage <= 0) return;
    isFlipping = true;
    
    const currentPageEl = pages[currentPage] as HTMLElement;
    const prevPageEl = pages[currentPage - 1] as HTMLElement;
    
    // Current page flips to show back
    currentPageEl.style.zIndex = '10';
    currentPageEl.style.transition = 'transform 0.6s ease-in';
    currentPageEl.style.transform = 'rotateY(180deg) translateZ(-5px)';
    
    setTimeout(() => {
      currentPageEl.style.zIndex = '0';
      currentPageEl.style.transition = '';
      currentPageEl.style.transform = 'rotateY(180deg) translateZ(0px)';
      
      // Previous page comes forward
      prevPageEl.style.zIndex = '5';
      prevPageEl.style.transition = 'transform 0.6s ease-out';
      prevPageEl.style.transform = 'rotateY(180deg) translateZ(0px)';
      
      currentPage--;
      
      setTimeout(() => {
        isFlipping = false;
      }, 400);
    }, 600);
  }
  
  // Restart button
  if (restartBtn) {
    restartBtn.addEventListener('click', () => {
      if (isFlipping) return;
      isFlipping = true;
      
      // Flip all pages back
      pages.forEach((page, index) => {
        const pageEl = page as HTMLElement;
        setTimeout(() => {
          pageEl.style.transition = 'transform 0.4s ease';
          pageEl.style.transform = 'rotateY(0deg) translateZ(0px)';
          pageEl.style.zIndex = '0';
        }, index * 50);
      });
      
      setTimeout(() => {
        cover.style.transition = 'transform 0.8s ease-in-out';
        cover.style.transform = 'translateZ(10px) rotateY(0deg)';
        currentPage = 0;
        
        setTimeout(() => {
          isFlipping = false;
        }, 400);
      }, pages.length * 50 + 200);
    });
  }
  
  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight' || e.key === ' ') {
      flipForward();
    } else if (e.key === 'ArrowLeft') {
      flipBackward();
    }
  });
</script>
